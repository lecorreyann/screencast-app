{
  "name": "screencast-app",
  "version": "1.0.0",
  "description": "Application simple de partage d'écran",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run server & npm run electron",
    "server": "node server/index.js",
    "electron": "electron .",
    "dev": "concurrently \"npm run server\" \"sleep 2 && npm run electron\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0"
  }
}
